{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "polars": {
      "type": "http",
      "url": "https://mcp.pola.rs/mcp"
    },
    "likec4": {
      "command": "npx",
      "args": [
        "-y",
        "@likec4/mcp"
      ]
    }
  }
}
