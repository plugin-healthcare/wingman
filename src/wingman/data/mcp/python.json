{
  "mcpServers": {
    "polars": {
      "type": "http",
      "url": "https://mcp.pola.rs/mcp"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "${workspaceFolder}"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "docs": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "Pydantic:https://docs.pydantic.dev/latest/llms.txt",
        "--transport",
        "stdio"
      ]
    }
  }
}
